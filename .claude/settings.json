{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(python SDLC/sdlc.py:*)",
      "Bash(python3 SDLC/sdlc.py:*)",
      "Bash(python -m pytest:*)",
      "Bash(pytest:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)"
    ],
    "ask": [
      "Edit(./.github/**)",
      "Write(./.github/**)",
      "Edit(./.claude/**)",
      "Write(./.claude/**)"
    ],
    "deny": [
      "Edit(./.sdlc/ledger/rounds.jsonl)",
      "Write(./.sdlc/ledger/rounds.jsonl)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f \"$CLAUDE_PROJECT_DIR/package.json\" ]; then if command -v bun >/dev/null 2>&1; then cd \"$CLAUDE_PROJECT_DIR\" && bun install; else echo \"ERROR: bun not found on PATH; install Bun (https://bun.sh) \u2014 it is a session prerequisite for this repo.\" >&2; exit 1; fi; fi"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/gate_guard.py\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/git_branch_guard.py\""
          },
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/bash_write_guard.py\""
          }
        ]
      }
    ]
  },
  "env": {
    "SDLC_ENFORCE": "block"
  }
}
